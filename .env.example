# Premium Real Estate Website - Environment variables sample
# Copy this file to .env and fill in the values:  cp .env.example .env

# Supabase (required)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# MapTiler (optional)
VITE_MAPTILER_API_KEY=

# Google Maps (optional)
VITE_GOOGLE_MAPS_API_KEY=

# Public site URL for sitemap.xml / robots.txt (no trailing slash)
VITE_SITE_URL=https://www.your-domain.com
